{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": ".",
    "rootDir": "."
  },
  "include": [
    "packages/plugins/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "test/**/*"
  ]
}
